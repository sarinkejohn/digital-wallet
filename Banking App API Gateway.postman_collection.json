                "value": "{{requestId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user001\",\n  \"password\": \"SecurePass123!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "localhost:9090/api/auth/register",
