    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "POST Register New User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Test 1: Status is 200 (or 201)",
                  "pm.test(\"Response status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Test 2: Token exists in response",
                  "pm.test(\"Token is present in response body\", function () {",
                  "    const responseData = pm.response.json();",
                  "    pm.expect(responseData.token).to.exist;",
                  "});",
                  "",
                  "// Test 3: Token is a non-empty string",
                  "pm.test(\"Token is a non-empty string\", function () {",
                  "    const responseData = pm.response.json();",
                  "    pm.expect(responseData.token).to.be.a('string').and.to.have.lengthOf.at.least(1, \"Token should not be empty\");",
                  "});",
                  "",
                  "// Test 4: Save token based on role",
                  "pm.test(\"Save token to environment variable based on role\", function () {",
                  "    const responseData = pm.response.json();",
                  "    const role = responseData.role;",
                  "    const token = responseData.token;",
                  "    ",
                  "    if (role === \"ADMIN\") {",
                  "        pm.globals.set(\"token-admin\", token);",
                  "        console.log(\"✅ Admin token saved as 'token-admin'\");",
                  "    } else if (role === \"USER\") {",
                  "        pm.globals.set(\"token-user\", token);",
                  "        console.log(\"✅ User token saved as 'token-user'\");",
                  "    } else {",
                  "        // Fallback for any other role",
                  "        pm.environment.set(\"authToken\", token);",
                  "        console.log(\"⚠️ Unknown role, token saved as 'authToken'\");",
                  "    }",
                  "    ",
                  "    // Also store user info for reference",
                  "    pm.environment.set(\"userId\", responseData.userId);",
                  "    pm.environment.set(\"role\", role);",
                  "    pm.environment.set(\"username\", responseData.username);",
                  "    ",
                  "    pm.expect(pm.globals.get(\"token-admin\") || pm.globals.get(\"token-user\") || pm.environment.get(\"authToken\")).to.exist;",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Channel",
                "value": "{{channel}}"
              },
              {
                "key": "AppId",
                "value": "{{appId}}"
              },
              {
                "key": "AppVersion",
                "value": "{{appVersion}}"
              },
              {
